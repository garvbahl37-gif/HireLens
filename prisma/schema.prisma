generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  FREE
  PRO
}

model User {
  id                     String    @id @default(cuid())
  email                  String    @unique
  passwordHash           String
  name                   String
  plan                   Plan      @default(FREE)

  /// Bumped on every password change and reset. The session JWT carries the
  /// value it was minted with, so bumping it invalidates every outstanding
  /// token at once -- which is what makes a password change actually evict a
  /// stolen 30-day session, and what "log out everywhere" would be built on.
  tokenVersion           Int       @default(0)

  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  cancelAtPeriodEnd      Boolean   @default(false)
  reviews                Review[]
  interviews             Interview[]
  tokens                 VerificationToken[]
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

enum TokenType {
  RESET
}

/// A single-use, short-lived token for out-of-band account actions.
/// Only the SHA-256 of the token is stored: a database leak must not hand the
/// attacker a working password-reset link.
model VerificationToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      TokenType
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

/// Fixed-window rate limit counters, keyed by a salted hash of the caller.
///
/// In Postgres rather than Redis because the app already has exactly one
/// stateful dependency and adding a second to count integers is a bad trade.
/// The window is advanced in a single atomic statement (see src/lib/ratelimit.ts),
/// so concurrent requests cannot both reset it.
model RateLimit {
  key         String   @id
  count       Int      @default(0)
  windowStart DateTime @default(now())
}

model Review {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobTitle       String
  company        String?
  resumeFilename String?
  resumeText     String
  jobDescription String
  overallScore   Int
  verdict        String
  result         Json
  deep           Boolean  @default(false)
  model          String

  /// Which revision of the analysis prompt produced this row. Scores from
  /// different prompt versions are not comparable, and the day someone edits
  /// buildSystemPrompt() the score trend would silently start lying without
  /// this. Rows written before the field existed are "legacy".
  promptVersion  String   @default("legacy")

  createdAt      DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

// Processed Stripe webhook events, for idempotency.
model StripeEvent {
  id        String   @id
  type      String
  createdAt DateTime @default(now())
}

enum InterviewStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

/// A mock interview: a resume-grounded, adaptive conversation with an AI
/// interviewer, ending in a scored report.
model Interview {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Optional provenance: the review this interview was launched from.
  reviewId       String?

  jobTitle       String
  company        String?
  resumeText     String
  jobDescription String

  status         InterviewStatus @default(IN_PROGRESS)

  /// The conversation so far: an array of { role, kind, content, askedAt }.
  /// Stored as JSON rather than a Turn table because a transcript is only ever
  /// read and written whole -- there is no query that wants a single turn.
  transcript     Json

  /// The resume claims to attack, snapshotted from the launching review at
  /// start (same discipline as `deep`/`totalQuestions`): editing the review
  /// afterwards must not mutate an interview already in flight. Null for
  /// interviews started from pasted text, which have no prior analysis. Shape
  /// is Claim[] from src/lib/ai.ts.
  claims         Json?

  /// Planned number of questions for this run (Pro gets a longer interview).
  totalQuestions Int
  /// How many questions have been ANSWERED.
  answered       Int             @default(0)

  /// The final scored report. Null until the interview is completed.
  report         Json?
  overallScore   Int?
  verdict        String?

  deep           Boolean         @default(false)
  model          String

  createdAt      DateTime        @default(now())
  completedAt    DateTime?

  @@index([userId, createdAt(sort: Desc)])
}
