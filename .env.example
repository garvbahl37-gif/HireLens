# --- Database (Postgres) ---
# Local dev: `npm run db:dev` boots an embedded Postgres on :55432
# Production: use a Neon/Supabase/Vercel-Postgres connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:55432/hirelens"
# Optional: a DIRECT (non-pooled) URL used ONLY for `prisma migrate deploy`.
# Set this in production if DATABASE_URL points at a PgBouncer pooler
# (Neon/Supabase). Leave empty for local dev.
DIRECT_URL=""

# --- Auth ---
# Secret used to sign session JWTs. Generate: openssl rand -base64 32
AUTH_SECRET="change-me"

# --- App ---
# Canonical URL of the deployment (no trailing slash). Used for Stripe redirects.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- AI provider — powers the resume analysis ---
# All providers speak the OpenAI wire format; the first key found wins.
# Groq (default, free tier at console.groq.com):
GROQ_API_KEY=""
GROQ_MODEL="openai/gpt-oss-120b"
# Alternatives, if you'd rather use them (leave GROQ_API_KEY empty):
# XAI_API_KEY=""        XAI_MODEL="grok-4.5"
# OPENAI_API_KEY=""     OPENAI_MODEL="gpt-4.1-mini"
#
# Set to "1" to skip the real AI call and return a realistic canned analysis
# (useful for local dev without an API key; never enable in production)
MOCK_AI=""

# --- Stripe (test mode) ---
# LEAVE THESE EMPTY to run billing in demo mode: checkout is simulated, but the
# upgrade still flows through the real webhook handler (see src/lib/demo-billing.ts).
# Fill them in to switch to live Stripe test mode — no code change needed.
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# From `stripe listen` locally, or the dashboard webhook endpoint in prod
STRIPE_WEBHOOK_SECRET=""
# Created by `npm run stripe:setup` (prints these values)
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_YEARLY=""
# Force demo billing even when Stripe keys ARE set (optional)
DEMO_BILLING=""
