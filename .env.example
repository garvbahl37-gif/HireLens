# --- Database (Postgres) ---
# Local dev: `npm run db:dev` boots an embedded Postgres on :55432
# Production: use a Neon/Supabase/Vercel-Postgres connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:55432/hirelens"

# --- Auth ---
# Secret used to sign session JWTs. Generate: openssl rand -base64 32
AUTH_SECRET="change-me"

# --- App ---
# Canonical URL of the deployment (no trailing slash). Used for Stripe redirects.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- xAI (Grok) — powers the resume analysis ---
XAI_API_KEY=""
XAI_MODEL="grok-4.5"
# Set to "1" to skip the real AI call and return a realistic canned analysis
# (useful for local dev without an API key; never enable in production)
MOCK_AI=""

# --- Stripe (test mode) ---
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# From `stripe listen` locally, or the dashboard webhook endpoint in prod
STRIPE_WEBHOOK_SECRET=""
# Created by `npm run stripe:setup` (prints these values)
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_YEARLY=""
